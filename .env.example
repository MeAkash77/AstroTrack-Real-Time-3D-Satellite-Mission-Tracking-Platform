# AstroTrack — self-host environment template
# Copy this file to .env and edit values before running docker compose up.
# The stack boots with built-in defaults even without a .env file, so this
# file is only needed when you want to override a value.
#
# WARNING: Change POSTGRES_PASSWORD before exposing this stack to the internet.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=astrotrack
POSTGRES_PASSWORD=astrotrack
POSTGRES_DB=astrotrack

# Full connection string consumed by the backend.
# Must match the POSTGRES_* values above.
ConnectionStrings__Postgres=Host=postgres;Database=astrotrack;Username=astrotrack;Password=astrotrack

# ── Backend runtime ───────────────────────────────────────────────────────────
# Use "Development" locally to enable Swagger UI at /swagger.
ASPNETCORE_ENVIRONMENT=Production

# CORS — origins the browser frontend is served from.
AstroTrack__Cors__AllowedOrigins__0=http://localhost:8080
AstroTrack__Cors__AllowedOrigins__1=http://localhost:5173

# ── OpenTelemetry (opt-in) ────────────────────────────────────────────────────
# Uncomment and set this to export traces and metrics to an OTel Collector.
# To use the bundled collector run:
#   docker compose --profile observability up
# then uncomment the line below:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
